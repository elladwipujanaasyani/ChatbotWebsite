<html>
<head>
	<title>Belajar Dasar Pemrograman Web</title>
	<link rel="stylesheet" type="text/css"
	media="all" href="model.css">
</head>
<body>
		<header>
		<h2>Tugas Akhir Membuat Website</h2>
			<nav>
			<ul>
				<li><a href="Pengertian Website.html">Pengertian Website</a></li>
				<li><a href="Tujuan Website.html">Tujuan Website</a></li>
				<li><a href="Manfaat Website.html">Manfaat Website</a></li>
			</ul>
			</nav>
		</header>
<main>
		<aside>
		<h3><center>Biodata Penulis</center></h3>
			<!--menampilkan gambar-->
				<img src="foto diri.png" class="gambardepan">
				<table class="table">
				<tr>
					<td> Nama </td>
					<td> :	Ella Dwipujana Asyani </td>
				</tr>
				<tr>
					<td> Jurusan </td>
					<td> :  Teknik Elektronika </td>
				</tr>
				<tr>
					<td> Perguruan Tinggi </td>
					<td> :  Universitas Negeri Padang </td>
				</tr>
				<tr>
					<td> Tempat Lahir </td>
					<td> :  Padang Pariaman</td>
				</tr>
				<tr>
					<td> Tanggal Lahir </td>
					<td> :  11 Januari 2003 </td>
				</tr>
				<tr>
					<td> Alamat </td>
					<td> :  Padang, Sumatera Barat </td>
				</tr>
				</table>
		</aside>
			<div id="content">
				<h2><center>Tujuan Website</center></h2>
				<table>
				<article>
				<tr>
					<td>
					Orang- orang dan perusahaan membuat situs web untuk tujuan yang berbeda, sebagian 
					diantaranya adalah untuk :<br>
					<br>- Menjual Produk dan Jasa
					<br>- Memposting dan mencari informasi di website
					<br>- Mendapatkan Pengetahuan
					<br>- Wadah untuk berkomunikasi satu sama lain, dll.
					</td>
				</tr>
				</article>
				</table>
			</div>
</main>
		<footer>21343022, Ella Dwipujana Asyani <br>
		Informatika, FT UNP
		</footer>
		    <!-- Chatbot -->
			<div class="chatbot-container" id="chatbot-container">
			<div class="chatbot-header">
            <span>Chatbot Perpustakaan</span>
            <button id="close-chatbot">×</button>
			</div>
        <div class="chatbot-body" id="chatbot-body">
            <div class="chatbot-message bot-message">Halo! Selamat datang di perpustakaan. Ada yang bisa saya bantu?</div>
        </div>
        <div class="chatbot-footer">
            <input type="text" id="user-input" placeholder="Tulis pesan di sini..." />
            <button id="send-message">Kirim</button>
        </div>
    </div>
    <img src="Gambar CS Fix.png" class="chatbot-icon" id="chatbot-icon" alt="Chatbot Icon">

    <script src="script.js"></script>
</body>
</html>